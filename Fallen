    local function update_local_tracer()
        if not settings.local_tracer then 
            if #cached_data.local_path > 0 then
                cached_data.local_path = {}
            end
            return 
        end
        
        local pos
        
        
        if entity and entity.get_local_player then
            local me = nil
            pcall(function() me = entity.get_local_player() end)
            if me and me.IsAlive then
                pcall(function() pos = me.Position end)
            end
        end
        
        if not pos then
            local lp = game.LocalPlayer
            if lp and lp.Character then
                local root = nil
                pcall(function() 
                    root = lp.Character:FindFirstChild("HumanoidRootPart") or lp.Character:FindFirstChild("Head")
                end)
                if root then
                    pcall(function() pos = root.Position end)
                end
            end
        end
        
        if not pos then return end
        
        local now = tick()
        local last_p = cached_data.local_path[#cached_data.local_path]
        local moved = true
        
        if last_p then
            local px, py, pz = 0, 0, 0
            pcall(function() 
                px, py, pz = pos.X, pos.Y, pos.Z
            end)
            local d = get_distance(px, py, pz, last_p.x, last_p.y, last_p.z)
            if d < 0.1 then 
                moved = false
            end
        end
        
        if moved then
            cached_data.last_move_time = now
            local px, py, pz = 0, 0, 0
            pcall(function() px, py, pz = pos.X, pos.Y, pos.Z end)
            table.insert(cached_data.local_path, {x = px, y = py, z = pz})
        else
            local fade_delay = (settings.local_tracer_fade or 3) * 1000
            if now - cached_data.last_move_time > fade_delay then
                if #cached_data.local_path > 0 then
                    if now - cached_data.last_fade_time > 50 then
                        table.remove(cached_data.local_path, 1)
                        cached_data.last_fade_time = now
                    end
                end
            end
        end
        
        local max_len = settings.local_tracer_length or 50
        while #cached_data.local_path > max_len do
            table.remove(cached_data.local_path, 1)
        end
    end

    local function draw_local_tracer()
        if not settings.local_tracer or #cached_data.local_path < 2 then return end
        
        local color = settings.local_tracer_color or {1, 1, 1, 1}
        local thickness = settings.local_tracer_thickness or 2
        
        for i = 1, #cached_data.local_path - 1 do
