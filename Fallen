    local function draw_gradient_rect(x, y, w, h, color1, color2, enabled2, rotation, force_manual, opacity)
        opacity = opacity or 1
        
        local c1 = {color1[1], color1[2], color1[3], color1[4] * opacity}
        local c2 = {color2[1], color2[2], color2[3], color2[4] * opacity}

        if not enabled2 then
            safe_rect_filled(x, y, w, h, c1)
            return
        end

        rotation = (rotation or 0) % 360
        
        if not force_manual then
            local is_horizontal = (rotation > 45 and rotation <= 135) or (rotation > 225 and rotation <= 315)
            if draw.gradient then
                draw.gradient(x, y, w, h, c1, c2, is_horizontal and 1 or 0)
                return
            elseif draw.gradient_rect then
                draw.gradient_rect(x, y, w, h, c1, c2, not is_horizontal)
                return
            elseif draw.rect_filled_gradient then
                draw.rect_filled_gradient(x, y, w, h, c1, c2, is_horizontal)
                return
            end
        end

        local rad = math.rad(rotation)
        local cos_a = math.cos(rad)
        local sin_a = math.sin(rad)
        
        local is_mostly_horizontal = math.abs(cos_a) > math.abs(sin_a)
        
        local x1, y1 = math.floor(x), math.floor(y)
        local x2, y2 = math.ceil(x + w), math.ceil(y + h)
        local iw, ih = x2 - x1, y2 - y1
        
        if iw <= 0 or ih <= 0 then return end
        
        local half_opacity = opacity * 0.55 
        local c1_h = {color1[1], color1[2], color1[3], color1[4] * half_opacity}
        local c2_h = {color2[1], color2[2], color2[3], color2[4] * half_opacity}

        if is_mostly_horizontal then
            for i = 0, iw do
                local curr_x = x1 + i
                local t_raw = ((curr_x + 0.5) - (x1 + iw/2)) * cos_a / (iw/2)
                local t = math.max(0, math.min(1, (t_raw + 1) / 2))
                
                local r = c1_h[1] + (c2_h[1] - c1_h[1]) * t
                local g = c1_h[2] + (c2_h[2] - c1_h[2]) * t
                local b = c1_h[3] + (c2_h[3] - c1_h[3]) * t
                local a = c1_h[4] + (c2_h[4] - c1_h[4]) * t
                
                safe_rect_filled(curr_x, y1, 2, ih, {r, g, b, a})
            end
        else
            for i = 0, ih do
                local curr_y = y1 + i
                local t_raw = ((curr_y + 0.5) - (y1 + ih/2)) * sin_a / (ih/2)
                local t = math.max(0, math.min(1, (t_raw + 1) / 2))
                
                local r = c1_h[1] + (c2_h[1] - c1_h[1]) * t
                local g = c1_h[2] + (c2_h[2] - c1_h[2]) * t
                local b = c1_h[3] + (c2_h[3] - c1_h[3]) * t
                local a = c1_h[4] + (c2_h[4] - c1_h[4]) * t
                
                safe_rect_filled(x1, curr_y, iw, 2, {r, g, b, a})
            end
        end
    end

    function draw_notifications()
        if not draw or not input then return end
        local now = tick()
        local screen_w, screen_h = get_screen_size()
        
        local font_size = settings and settings.esp_text_size or 14
        local width_scale = 1.0
        local x_pos_val = 20
        local y_pos_val = 20
        
        local padding = 15 * (font_size / 14)
        local spacing = 10 * (font_size / 14)
        local target_y_start = y_pos_val
        local current_target_y = target_y_start
        
        for i = #notifications, 1, -1 do
            local n = notifications[i]
            local elapsed = now - n.time
            
            if elapsed > n.duration then
                table.remove(notifications, i)
            else
                local fade_time = 400
                local slide_speed = 0.15
                
                local target_alpha = 1
                if elapsed < fade_time then
                    target_alpha = elapsed / fade_time
                elseif elapsed > n.duration - fade_time then
                    target_alpha = (n.duration - elapsed) / fade_time
                end
                n.alpha = lerp(n.alpha or 0, target_alpha, 0.2)
                
                local target_x_off = 0
                if elapsed > n.duration - fade_time then
                    target_x_off = 100
                end
                n.x_offset = lerp(n.x_offset or 100, target_x_off, slide_speed)
                
                if n.current_y == 0 then n.current_y = current_target_y end
                n.current_y = lerp(n.current_y, current_target_y, 0.2)
                
                local icon = "[!]"
                local accent_color = {0.1, 0.6, 1, 1}
                
                if n.type == "success" then
                    icon = "[+]"
                    accent_color = {0.2, 0.8, 0.2, 1}
                elseif n.type == "warning" then
                    icon = "[!]"
                    accent_color = {1, 0.8, 0.2, 1}
                elseif n.type == "danger" then
                    icon = "[X]"
                    accent_color = {1, 0.2, 0.2, 1}
                end
                
                local display_text = string.format("%s %s", icon, n.msg)
                local text_w, text_h = draw.get_text_size(display_text, font_size)
                local rect_w = (text_w + (padding * 2)) * width_scale
                local rect_h = text_h + (padding * 1.2)
                
                local x = screen_w - rect_w - x_pos_val + n.x_offset
                local y = n.current_y
                
                local a = n.alpha
                
                safe_rect_filled(x + 2, y + 2, rect_w, rect_h, {0, 0, 0, 0.4 * a})
                
                safe_rect_filled(x, y, rect_w, rect_h, {0.05, 0.05, 0.05, 0.85 * a})
                
                safe_rect_filled(x, y, 3, rect_h, {accent_color[1], accent_color[2], accent_color[3], 1 * a})
                
                if draw.rect then
                    draw.rect(x, y, rect_w, rect_h, {accent_color[1], accent_color[2], accent_color[3], 0.3 * a})
                end
                
                local icon_w, _ = draw.get_text_size(icon .. " ", font_size)
                draw.text(x + padding, y + (padding * 0.6), icon, {accent_color[1], accent_color[2], accent_color[3], 1 * a}, font_size)
                draw.text(x + padding + icon_w, y + (padding * 0.6), n.msg, {1, 1, 1, 1 * a}, font_size)
                
                current_target_y = current_target_y + rect_h + spacing
            end
        end
    end

