    local function get_env()
        local success, genv = pcall(function() return getgenv() end)
        if success and type(genv) == "table" then return genv end
        return _G or {}
    end

    local function get_rbx_global(name)
        
        local val = _G[name] or (getgenv and getgenv()[name]) or getfenv(0)[name]
        
       
        if not val then
            if name == "Instance" then val = Instance end
            if name == "UDim2" then val = UDim2 end
            if name == "Color3" then val = Color3 end
            if name == "Enum" then val = Enum end
            if name == "game" then val = game end
            if name == "workspace" then val = workspace end
        end

        
        if not val then
            local env = get_env()
            val = env[name]
            
            if not val then
                local success_shared, shared_env = pcall(function() return shared end)
                if success_shared and type(shared_env) == "table" then
                    val = shared_env[name]
                end
            end
        end

        
        if name == "game" and not val then
            pcall(function() val = game end)
        end

        
        local cloneref = (getgenv and getgenv().cloneref) or _G.cloneref
        if cloneref and type(val) == "userdata" then
            local success, cloned = pcall(function() return cloneref(val) end)
            if success then return cloned end
        end

        return val
    end

