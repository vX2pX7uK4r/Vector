    local function scan_events()
        local found_set = {}
        
        local function determine_location(obj, pos)
            local name = obj.Name
            local parent = obj.Parent
            
            
            local extra_info = ""
            if name == "Timed Crate" or (parent and parent.Name == "Timed Crate") then
                local text_label = obj:FindFirstDescendant("TextLabel")
                if text_label and text_label:IsA("TextLabel") then
                    local text = text_label.Text
                    if text and text ~= "" then
                        extra_info = " (" .. text .. ")"
                    end
                end
            end
            
            
            local current = parent
            while current and current ~= game.Workspace do
                local c_name = current.Name
                if c_name ~= name and 
                    c_name ~= "Events" and 
                    c_name ~= "Folder" and 
                    c_name ~= "Models" and 
                    c_name ~= "NPCs" and
                    c_name ~= "World" and
                    c_name ~= "Loners" and
                    c_name ~= "Bases" and
                    c_name ~= "Timed Crate" and
                    c_name ~= "Care Package" and
                    not c_name:find("Model") then
                    return c_name .. extra_info
                end
                current = current.Parent
            end
            
            if pos then
                local loc = get_nearest_location(pos.X, pos.Y, pos.Z)
                if loc ~= "Unknown" then
                    return loc .. extra_info
                end
            end
            
            return "Unknown" .. extra_info
        end

        
        if game_folders.events then
            local children = game_folders.events:GetChildren()
            for i = 1, #children do
                local child = children[i]
                if child and (child:IsA("Model") or child:IsA("BasePart")) then
                    local pos = (child:IsA("Model") and child.PrimaryPart and child.PrimaryPart.Position) or (child:IsA("BasePart") and child.Position) or find_first_part(child) and find_first_part(child).Position
                    local loc = determine_location(child, pos)
                    found_set[child] = { name = child.Name, location = loc }
                end
            end
        end

        
        if game_folders.bases then
            local loners = game_folders.bases:FindFirstChild("Loners")
            if loners then
                local tc_folder = loners:FindFirstChild("Timed Crate")
                if tc_folder then
                    local crates = tc_folder:GetChildren()
                    for i = 1, #crates do
                        local crate = crates[i]
                        if crate:IsA("Model") then
                            local pos = (crate.PrimaryPart and crate.PrimaryPart.Position) or find_first_part(crate) and find_first_part(crate).Position
                            local loc = determine_location(crate, pos)
                            found_set[crate] = { name = "Timed Crate", location = loc }
                        end
                    end
                end
                local cp_folder = loners:FindFirstChild("Care Package")
                if cp_folder then
                    local packages = cp_folder:GetChildren()
                    for i = 1, #packages do
                        local package = packages[i]
                        if package:IsA("Model") then
                            local pos = (package.PrimaryPart and package.PrimaryPart.Position) or find_first_part(package) and find_first_part(package).Position
                            local loc = determine_location(package, pos)
                            found_set[package] = { name = "Care Package", location = loc }
                        end
                    end
                end
            end
        end

        
        if game_folders.military then
            local boss_names = { ["Boris"] = true, ["Bruno"] = true, ["Brutus"] = true }
            local monuments = game_folders.military:GetChildren()
            for i = 1, #monuments do
                local mon = monuments[i]
                local npcs = mon:GetChildren()
                for j = 1, #npcs do
                    local npc = npcs[j]
                    if npc:IsA("Model") and boss_names[npc.Name] then
                        local humanoid = npc:FindFirstChildOfClass("Humanoid")
                        if humanoid and humanoid.Health > 0 then
                            local pos = (npc.PrimaryPart and npc.PrimaryPart.Position) or find_first_part(npc) and find_first_part(npc).Position
                            local loc = determine_location(npc, pos)
                            found_set[npc] = { name = npc.Name, location = loc }
                        end
                    end
                end
            end
        end
        
        
        for obj, data in pairs(found_set) do
            
            if cached_data.events[obj] then
                cached_data.events[obj].location = data.location
            else
                cached_data.events[obj] = data
                
                
                if not cached_data.notified_events[data.name] then
                    cached_data.notified_events[data.name] = true
                    safe_notify("New Event: " .. data.name .. " - [" .. data.location .. "]", "info")
                end
            end
        end
        
    
        for obj, _ in pairs(cached_data.events) do
            if not found_set[obj] then
                cached_data.events[obj] = nil
            end
        end
    end

    local function is_target_valid(target)
        if not target then return false end
        local health = 0
        local exists = false
        pcall(function()
            if target.humanoid and target.humanoid.Parent then
                health = target.humanoid.Health
                exists = true
            end
        end)
        return exists and health > 0
    end

    local function get_local_weapon_stats()
        local lp = game.LocalPlayer
        if not lp or not lp.Character then return nil end
        
        local held_item_name = nil
        local held_item_obj = nil
        
        
        local ok_c, char_children = pcall(function() return lp.Character:GetChildren() end)
        if ok_c and char_children then
            for i = 1, #char_children do
                local child = char_children[i]
                if child and WEAPON_ITEMS[child.Name] then
                    held_item_name = child.Name
                    held_item_obj = child
                    break
                end
            end
        end
        
    
        if not held_item_name then
            local viewmodels = game.Workspace:FindFirstChild("Viewmodels")
            if viewmodels then
                local ok_v, children = pcall(function() return viewmodels:GetChildren() end)
                if ok_v and children then
                    for i = 1, #children do
                        local vm = children[i]
                        if vm and vm.Name == "Viewmodel" then
                            local ok_vm, vm_children = pcall(function() return vm:GetChildren() end)
                            if ok_vm and vm_children then
                                for j = 1, #vm_children do
                                    local item = vm_children[j]
                                    if item and item.ClassName == "Model" and WEAPON_ITEMS[item.Name] then
                                        held_item_name = item.Name
                                        held_item_obj = item
                                        break
                                    end
                                end
                            end
                        end
                        if held_item_name then break end
                    end
                end
            end
        end
        
        if held_item_name then
        
            local speed, gravity
            pcall(function()
                speed = held_item_obj:GetAttribute("BulletSpeed") or held_item_obj:GetAttribute("MuzzleVelocity")
                gravity = held_item_obj:GetAttribute("BulletGravity") or held_item_obj:GetAttribute("ProjectileGravity")
            end)
            
            if speed then
                return { speed = speed, gravity = gravity or 35 }
            end
            
        
            return WEAPON_STATS[held_item_name]
        end
        
        return nil
    end

    local function run_aimbot()
        if not settings.aimbot_enabled then 
            locked_target = nil
            return 
        end
        local scx, scy = get_screen_center()
        if settings.aimbot_draw_fov then
            local fov_color = settings.aimbot_fov_color
            draw.circle(scx, scy, settings.aimbot_fov, fov_color, 64)
            if settings.aimbot_prediction or settings.aimbot_drop_prediction then
                local indicators = {}
                if settings.aimbot_prediction and settings.aimbot_prediction_indicator then 
                    table.insert(indicators, {text = "[Movement Prediction]", color = settings.aimbot_prediction_indicator_color}) 
                end
                if settings.aimbot_drop_prediction and settings.aimbot_drop_prediction_indicator then 
                    table.insert(indicators, {text = "[Drop Calculation]", color = settings.aimbot_drop_prediction_indicator_color}) 
                end
                if settings.aimbot_auto_weapon and settings.aimbot_auto_weapon_indicator then
                    local auto_stats = get_local_weapon_stats()
                    if auto_stats then
                        table.insert(indicators, {text = "[Automatic Weapon Calculation]", color = settings.aimbot_auto_weapon_indicator_color})
                    end
                end

                local total_width = 0
                local spacing = 5
                for i, ind in ipairs(indicators) do
                    local tw = draw.get_text_size(ind.text, settings.esp_text_size - 2)
                    total_width = total_width + tw + (i < #indicators and spacing or 0)
                end

                local current_x = scx - total_width * 0.5
                local draw_y = scy + settings.aimbot_fov + 5
                for i, ind in ipairs(indicators) do
                    draw.text(current_x, draw_y, ind.text, ind.color, settings.esp_text_size - 2)
                    local tw = draw.get_text_size(ind.text, settings.esp_text_size - 2)
                    current_x = current_x + tw + spacing
                end
            end
        end
        local main_key = menu.get_key("aimbot_enabled")
        local is_main_down = (main_key > 0 and input.is_key_down(main_key))
        
        local cam_x = cached_data.camera_x
        local cam_y = cached_data.camera_y
        local cam_z = cached_data.camera_z
        local best_fov = settings.aimbot_fov
        local best_pos = nil
        local bone_name = AIM_BONES[settings.aimbot_bone]
        
        local targets = {}
        
        local n_key = menu.get_key("aimbot_npcs")
        local aiming_at_npcs = false
        if settings.aimbot_npc_mode == 1 then
            aiming_at_npcs = (n_key > 0 and input.is_key_down(n_key))
        else
            aiming_at_npcs = settings.aimbot_npcs and is_main_down
        end
        
        if aiming_at_npcs then
            for i = 1, #cached_data.npcs do
                targets[#targets + 1] = cached_data.npcs[i]
            end
        end
        
        local p_key = menu.get_key("aimbot_players")
        local aiming_at_players = false
        if settings.aimbot_player_mode == 1 then
            aiming_at_players = (p_key > 0 and input.is_key_down(p_key))
        else
            aiming_at_players = settings.aimbot_players and is_main_down
        end

        if aiming_at_players then
            for i = 1, #cached_data.players do
                local p = cached_data.players[i]
                targets[#targets + 1] = p
            end
        end

        if not (aiming_at_npcs or aiming_at_players) then
            locked_target = nil
            return
        end

        if #targets == 0 then
            locked_target = nil
            return
        end

        local function get_aim_pos(target)
            local health = 0
            local aim_part = nil
            
            if target.humanoid then
                health = target.humanoid.Health or 0
                local part_data = target.parts[bone_name]
                if part_data and part_data.part then
                    aim_part = part_data.part
                end
            elseif target.parts then
                health = (target.humanoid and target.humanoid.Health) or 100
                local part_data = target.parts[bone_name]
                if part_data and part_data.part then
                    aim_part = part_data.part
                end
            end

            if health > 0 and aim_part then
                local pos = aim_part.Position
                if pos then
                    local px, py, pz = pos.X, pos.Y, pos.Z
                    local dist_to_target = get_distance(px, py, pz, cam_x, cam_y, cam_z)
                    local aim_x, aim_y, aim_z = px, py, pz
                    
                    local bullet_speed = settings.aimbot_bullet_speed or 1000
                    local gravity = settings.aimbot_gravity or 35
                    
                    
                    if settings.aimbot_auto_weapon then
                        local auto_stats = get_local_weapon_stats()
                        if auto_stats then
                            bullet_speed = auto_stats.speed
                            gravity = auto_stats.gravity
                        end
                    end

                    local time_to_hit = dist_to_target / bullet_speed
                    
                    if settings.aimbot_prediction then
                        local vel = nil
                        pcall(function()
                            local root = target.root_part or (target.parts and target.parts.HumanoidRootPart and target.parts.HumanoidRootPart.part)
                            local source = root or aim_part
                            if source.AssemblyLinearVelocity then
                                vel = source.AssemblyLinearVelocity
                            elseif source.Velocity then
                                vel = source.Velocity
                            end
                        end)
                        
                        if vel then
                            aim_x = px + vel.X * time_to_hit
                            aim_y = py + vel.Y * time_to_hit
                            aim_z = pz + vel.Z * time_to_hit
                        end
                    end
                    
                    if settings.aimbot_drop_prediction then
                        local drop = 0.5 * gravity * (time_to_hit * time_to_hit)
                        aim_y = aim_y + drop
                    end
                    
                    return {x = aim_x, y = aim_y, z = aim_z}
                end
            end
            return nil
        end

    
        if settings.aimbot_sticky and locked_target then
            if is_target_valid(locked_target) then
                local pos = get_aim_pos(locked_target)
                if pos then
                    local sx, sy, vis = utility.WorldToScreen(pos.x, pos.y, pos.z)
                    if vis then
                        local dx, dy = sx - scx, sy - scy
                        local fov = sqrt(dx * dx + dy * dy)
                        if fov < settings.aimbot_fov then
                            best_pos = pos
                        else
                            locked_target = nil
                        end
                    else
                        locked_target = nil
                    end
                else
                    locked_target = nil
                end
            else
                locked_target = nil
            end
        end

        
        if not best_pos then
            for i = 1, #targets do
                local target = targets[i]
                local pos = get_aim_pos(target)
                if pos then
                    local sx, sy, vis = utility.WorldToScreen(pos.x, pos.y, pos.z)
                    if vis then
                        local dx, dy = sx - scx, sy - scy
                        local fov = sqrt(dx * dx + dy * dy)
                        if fov < best_fov then
                            best_fov = fov
                            best_pos = pos
                            locked_target = target
                        end
                    end
                end
            end
        end

        if best_pos then
            camera.look_at(best_pos.x, best_pos.y, best_pos.z, settings.aimbot_smooth)
        end
    end

