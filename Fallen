    local function track_hits()
        if not settings.hit_notifier and not settings.hitmarker_enabled then return end
        
        local is_shooting = input.is_key_down(0x01) 
        local now = tick()
        
        if is_shooting then
            cached_data.last_shooting_tick = now
        end
        
        local recently_shooting = (now - (cached_data.last_shooting_tick or 0)) < 150
        local screen_w, screen_h = get_screen_size()
        local cross_x, cross_y = screen_w / 2, screen_h / 2
        local fov_limit = settings.aimbot_fov or 50
        if fov_limit < 50 then fov_limit = 50 end 
        
        cached_data.last_is_shooting = is_shooting
        
        
        local all_targets = {}
        for i = 1, #cached_data.players do table.insert(all_targets, cached_data.players[i]) end
        for i = 1, #cached_data.npcs do table.insert(all_targets, cached_data.npcs[i]) end
        if cached_data.btr then
            for i = 1, #cached_data.btr do table.insert(all_targets, cached_data.btr[i]) end
        end

        for i = 1, #all_targets do
            local target = all_targets[i]
            if not target then goto next_t end
            
            local target_id = target.UserId or (target.obj and tostring(target.obj)) or target.name
            local current_health = 0
            if target.humanoid then
                pcall(function() current_health = target.humanoid.Health end)
            end
            
            local last_health = cached_data.player_health_history[target_id]
            
            
            if last_health and type(last_health) == "number" and type(current_health) == "number" and current_health < last_health and current_health >= 0 then
                
                local last_notify = last_hit_notification_time[target_id] or 0
                if now - last_notify > 50 then 
                    local was_aiming_at = false
                    if locked_target then
                        if locked_target.UserId and target.UserId then
                            was_aiming_at = (locked_target.UserId == target.UserId)
                        elseif locked_target.name and target.name then
                            was_aiming_at = (locked_target.name == target.name)
                        end
                    end
                    
                    
                    local near_crosshair = false
                    local best_hit_part = "Body"
                    local min_dist = fov_limit
                    
                    
                    if (recently_shooting or is_shooting) and not was_aiming_at then
                        if target.parts then
                            for part_name, part_data in pairs(target.parts) do
                                local p = part_data.part
                                if p then
                                    local pos = p.Position
                                    local sx, sy, vis = utility.WorldToScreen(pos.X, pos.Y, pos.Z)
                                    if vis then
                                        local d = get_distance(sx, sy, 0, cross_x, cross_y, 0)
                                        if d < min_dist then
                                            min_dist = d
                                            near_crosshair = true
                                            best_hit_part = part_name
                                        end
                                    end
                                end
                            end
                        end
                        
                        
                        if not near_crosshair and target.root_part then
                            local sx, sy, vis = utility.WorldToScreen(target.root_part.Position.X, target.root_part.Position.Y, target.root_part.Position.Z)
                            if vis then
                                local d = get_distance(sx, sy, 0, cross_x, cross_y, 0)
                                if d < fov_limit * 1.5 then 
                                    near_crosshair = true
                                    best_hit_part = "HumanoidRootPart"
                                end
                            end
                        end
                    end

                    
                    local is_manual_shot = (recently_shooting or is_shooting) and near_crosshair
                    local is_aimbot_hit = was_aiming_at and (recently_shooting or is_shooting or settings.aimbot_auto_shoot)
                    
                    if is_manual_shot or is_aimbot_hit then
                        
                        if is_aimbot_hit and not near_crosshair then
                            best_hit_part = AIM_BONES[settings.aimbot_bone] or "Head"
                        end

                        
                        local display_name = target.name or "Unknown"
                        local is_btr_hit = false
                        if target.obj then
                            local p = target.obj
                            for _ = 1, 3 do
                                if not p or p == game then break end
                                if p.Name == "BTR" or p.Name == "Events" then
                                    if p.Name == "BTR" then
                                        display_name = "BTR"
                                        is_btr_hit = true
                                        break
                                    end
                                end
                                p = p.Parent
                            end
                        end

                        
                        if display_name == "Soldier" and not is_btr_hit then
                            goto next_t
                        end

                        last_hit_notification_time[target_id] = now
                        
                        
                        local clean_part = best_hit_part
                        if find(clean_part, "Leg") then clean_part = "Leg"
                        elseif find(clean_part, "Arm") then clean_part = "Arm"
                        elseif find(clean_part, "Hand") then clean_part = "Arm"
                        elseif find(clean_part, "Foot") then clean_part = "Leg"
                        elseif find(clean_part, "Torso") or find(clean_part, "UpperBody") then clean_part = "Body"
                        end

                    
                        if settings.hit_notifier then
                            local msg = string.format("[%s - %s - %.0fm - %.0f HP]", 
                                display_name, 
                                clean_part, 
                                target.dist or 0, 
                                current_health)
                            safe_notify(msg, "info", true)
                        end

                    
                        if settings.hitmarker_enabled then
                            local hit_pos = nil
                            if target.parts and target.parts[best_hit_part] then
                                local p = target.parts[best_hit_part].part
                                if p then hit_pos = p.Position end
                            elseif target.root_part then
                                hit_pos = target.root_part.Position
                            end

                            if hit_pos then
                                table.insert(cached_data.hitmarkers, {
                                    pos = hit_pos,
                                    time = now,
                                    alpha = 1.0
                                })
                            end
                        end
                    end
                end
            end
            
        
            cached_data.player_health_history[target_id] = current_health
            ::next_t::
        end
    end

