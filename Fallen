    local function hsv_to_rgb(h, s, v)
        local r, g, b
        local i = math.floor(h * 6)
        local f = h * 6 - i
        local p = v * (1 - s)
        local q = v * (1 - f * s)
        local t = v * (1 - (1 - f) * s)
        i = i % 6
        if i == 0 then r, g, b = v, t, p
        elseif i == 1 then r, g, b = q, v, p
        elseif i == 2 then r, g, b = p, v, t
        elseif i == 3 then r, g, b = p, q, v
        elseif i == 4 then r, g, b = t, p, v
        elseif i == 5 then r, g, b = v, p, q
        end
        return r, g, b
    end

    local function draw_offscreen_arrow(target_pos, color, radius, size, pulse, show_distance, distance, speed, rainbow, stacking)
        local scx, scy = get_screen_center()
        if scx == 0 or scy == 0 then return end
        local sw, sh = scx * 2, scy * 2
        
        local tx, ty, vis = utility.WorldToScreen(target_pos.X, target_pos.Y, target_pos.Z)
        
        local margin = 30
        local is_on_screen = vis and tx > -margin and tx < sw + margin and ty > -margin and ty < sh + margin
        
        if is_on_screen then return end

        local dx, dy, angle
        if not vis then
            local cam_x, cam_y, cam_z = cached_data.camera_x, cached_data.camera_y, cached_data.camera_z
            local wdx = target_pos.X - cam_x
            local wdz = target_pos.Z - cam_z
            
            local yaw_deg = cached_data.camera_yaw or 0
            local yaw = math.rad(yaw_deg)
            
            local cos_y = math.cos(-yaw - math.pi/2)
            local sin_y = math.sin(-yaw - math.pi/2)
            
            local rot_x = wdx * cos_y - wdz * sin_y
            local rot_y = wdx * sin_y + wdz * cos_y
            
            angle = math.atan2(rot_y, rot_x)
        else
            dx, dy = tx - scx, ty - scy
            angle = math.atan2(dy, dx)
        end
        
        local final_radius = radius
        if stacking then
            local now_ms = tick()
            if math.abs(now_ms - last_frame_time) > 1 then
                offscreen_slots = {}
                last_frame_time = now_ms
            end
            
            local sector = math.floor(math.deg(angle) / 20)
            local slot = offscreen_slots[sector] or 0
            final_radius = radius + (slot * (size * 1.2))
            offscreen_slots[sector] = slot + 1
        end

        local fade = 1.0
        if vis then
            local dist_from_center = math.sqrt((tx-scx)^2 + (ty-scy)^2)
            local screen_radius = math.sqrt(scx*scx + scy*scy)
            fade = math.min(1.0, (dist_from_center - screen_radius * 0.7) / (screen_radius * 0.3))
        end
        fade = math.max(0.2, fade)

        local now = tick() / 1000
        local final_speed = (speed or 8) * 0.5 
        
        local r, g, b, a = color[1], color[2], color[3], color[4] * fade
        if rainbow then
            local hue = (now * 0.3) % 1.0
            local rr, gg, bb = hsv_to_rgb(hue, 0.7, 1.0)
            r, g, b = rr, gg, bb
        end

        local pulse_val = 1.0
        local pulse_radius = 0
        if pulse and final_speed > 0 then
            local wave = math.sin(now * final_speed)
            pulse_val = 1.0 + wave * 0.1
            pulse_radius = wave * 5
            a = a * (0.8 + wave * 0.2)
        end
        
        if a <= 0 then return end
        
        final_radius = final_radius + pulse_radius
        local final_size = size * pulse_val
        
        local cos_a = math.cos(angle)
        local sin_a = math.sin(angle)
        
        local cx = scx + cos_a * final_radius
        local cy = scy + sin_a * final_radius
        
        local p1x = cx + cos_a * (final_size * 1.2)
        local p1y = cy + sin_a * (final_size * 1.2)
        local side_angle = math.rad(140)
        local p2x = cx + math.cos(angle + side_angle) * (final_size * 0.8)
        local p2y = cy + math.sin(angle + side_angle) * (final_size * 0.8)
        local p3x = cx + math.cos(angle - side_angle) * (final_size * 0.8)
        local p3y = cy + math.sin(angle - side_angle) * (final_size * 0.8)
        local p4x = cx + cos_a * (final_size * 0.2)
        local p4y = cy + sin_a * (final_size * 0.2)

        for i = 1, 8 do
            local step = i / 8
            local layer_a = a * (0.15 * step)
            local lx2 = p2x + (p1x - p2x) * (1 - step)
            local ly2 = p2y + (p1y - p2y) * (1 - step)
            local lx3 = p3x + (p1x - p3x) * (1 - step)
            local ly3 = p3y + (p1y - p3y) * (1 - step)
            draw.line(p4x, p4y, lx2, ly2, {r, g, b, layer_a}, 1)
            draw.line(p4x, p4y, lx3, ly3, {r, g, b, layer_a}, 1)
            draw.line(lx2, ly2, lx3, ly3, {r, g, b, layer_a}, 1)
        end

        draw.line(p1x, p1y, p2x, p2y, {r, g, b, a}, 3)
        draw.line(p1x, p1y, p3x, p3y, {r, g, b, a}, 3)
        
        draw.line(p2x, p2y, p4x, p4y, {r, g, b, a * 0.6}, 2)
        draw.line(p3x, p3y, p4x, p4y, {r, g, b, a * 0.6}, 2)
        
        if draw.circle_filled then
            draw.circle_filled(p1x, p1y, 3, {1, 1, 1, a * 0.5})
        end

        if show_distance and distance then
            local dist_text = math.floor(distance) .. "m"
            local font_size = settings.esp_text_size or 11
            local tw = draw.get_text_size(dist_text, font_size)
            local tx_pos = scx + cos_a * (final_radius + final_size + 20)
            local ty_pos = scy + sin_a * (final_radius + final_size + 20)
            
            if draw.rect_filled then
                draw.rect_filled(tx_pos - tw/2 - 3, ty_pos - font_size/2 - 2, tw + 6, font_size + 4, {0, 0, 0, a * 0.6})
            end
            draw.text(tx_pos - tw/2, ty_pos - font_size/2, dist_text, {1, 1, 1, a}, font_size)
        end
    end

