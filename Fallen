            local s2x, s2y, v2 = utility.WorldToScreen(p2.x, p2.y, p2.z)
            
            if v1 and v2 then
                draw.line(s1x, s1y, s2x, s2y, color, thickness)
            end
        end
    end

    local function get_time_seconds() 
        if draw and draw.get_time then return draw.get_time() end 
        if draw and draw.get_time_seconds then return draw.get_time_seconds() end 
        return os.clock() 
    end

    local function draw_hitmarkers()
        if not settings.hitmarker_enabled then 
            cached_data.hitmarkers = {}
            return 
        end
        
        local now = tick()
        local duration = settings.hitmarker_duration or 500
        local size = settings.hitmarker_size or 5
        local color = menu.get_color("hitmarker_enabled") or {1, 1, 1, 1}
        
        for i = #cached_data.hitmarkers, 1, -1 do
            local hm = cached_data.hitmarkers[i]
            local elapsed = now - hm.time
            
            if elapsed > duration then
                table.remove(cached_data.hitmarkers, i)
            else
                local alpha = 1 - (elapsed / duration)
                local sx, sy, vis = utility.WorldToScreen(hm.pos.X, hm.pos.Y, hm.pos.Z)
                
                if vis then
                    sx, sy = math.floor(sx), math.floor(sy)
                    local draw_color = {color[1], color[2], color[3], color[4] * alpha}
                    
                
                    if settings.hitmarker_glow then

                        for g = 1, 5 do
                            local glow_alpha = (alpha * 0.12) 
                            local glow_color = {color[1], color[2], color[3], glow_alpha}
                            local glow_thickness = 1 + (g * 1.2)
                            
                            draw.line(sx - size, sy - size, sx + size, sy + size, glow_color, math.floor(glow_thickness))
                            draw.line(sx + size, sy - size, sx - size, sy + size, glow_color, math.floor(glow_thickness))
                        end
                    end


                    draw.line(sx - size, sy - size, sx + size, sy + size, draw_color, 2)
                    draw.line(sx + size, sy - size, sx - size, sy + size, draw_color, 2)

                    
                    if settings.hitmarker_glow then
                        local highlight_alpha = alpha * 0.5
                        local highlight_color = {color[1], color[2], color[3], highlight_alpha}
                        draw.line(sx - size, sy - size, sx + size, sy + size, highlight_color, 1)
                        draw.line(sx + size, sy - size, sx - size, sy + size, highlight_color, 1)
                    end
                end
            end
        end
    end

    local function draw_crosshair()
        if not settings.xhair_enabled then return end
        
        local scx, scy = get_screen_center()
        if scx == 0 or scy == 0 then return end
        
        local t = get_time_seconds()
        local size = settings.xhair_size
        
        
        if settings.xhair_pulse_speed > 0 then
            local pulse = math.sin(t * settings.xhair_pulse_speed) * settings.xhair_pulse_size
            size = size + pulse
        end

        local gap = settings.xhair_gap
        local thickness = settings.xhair_thickness
        local color = settings.xhair_color or {0, 1, 0, 1}
        if settings.xhair_rainbow then
            local speed = settings.xhair_rainbow_speed or 10
            local hue = (t * (speed / 100)) % 1.0
            local r, g, b = hsv_to_rgb(hue, 0.7, 1.0)
            color = {r, g, b, color[4] or 1}
        end
        local outline = settings.xhair_outline
        local outline_color = settings.xhair_outline_color or {0, 0, 0, 1}
        local type = settings.xhair_type 
        
        local rot_speed = settings.xhair_rotate_speed or 0
        local rot = t * rot_speed

        if settings.xhair_dot then
            local dot_color = settings.xhair_dot_color or {1, 1, 1, 1}
            if outline then
                safe_rect_filled(scx - 1, scy - 1, 3, 3, outline_color)
            end
            safe_rect_filled(scx, scy, 1, 1, dot_color)
        end

        if type == 1 or type == 4 then 
            local start_y = (type == 4) and 1 or -1
            
            if rot_speed > 0 then
                
                local function draw_rotated_rect(offset_x, offset_y, w, h, col, thick)
                    local ca, sa = math.cos(rot), math.sin(rot)
                    local function rp(lx, ly)
                        return scx + lx*ca - ly*sa, scy + lx*sa + ly*ca
                    end
                    
                    local p1x, p1y = rp(offset_x, offset_y)
                    local p2x, p2y = rp(offset_x + w, offset_y)
                    local p3x, p3y = rp(offset_x + w, offset_y + h)
                    local p4x, p4y = rp(offset_x, offset_y + h)
                    

                    draw.line(p1x, p1y, p2x, p2y, col, thick)
                    draw.line(p2x, p2y, p3x, p3y, col, thick)
                    draw.line(p3x, p3y, p4x, p4y, col, thick)
                    draw.line(p4x, p4y, p1x, p1y, col, thick)
                end

                if outline then
                    local ot = thickness + 2
                    draw_rotated_rect(-gap - size - 1, -(thickness/2) - 1, size + 2, ot, outline_color, 1)
                    draw_rotated_rect(gap - 1, -(thickness/2) - 1, size + 2, ot, outline_color, 1)
                    if type == 1 then
                        draw_rotated_rect(-(thickness/2) - 1, -gap - size - 1, ot, size + 2, outline_color, 1)
                    end
                    draw_rotated_rect(-(thickness/2) - 1, gap - 1, ot, size + 2, outline_color, 1)
                end

                draw_rotated_rect(-gap - size, -(thickness/2), size, thickness, color, thickness)
                draw_rotated_rect(gap, -(thickness/2), size, thickness, color, thickness)
                if type == 1 then
                    draw_rotated_rect(-(thickness/2), -gap - size, thickness, size, color, thickness)
                end
                draw_rotated_rect(-(thickness/2), gap, thickness, size, color, thickness)
            else
                
                if outline then
                    local o_thick = thickness + 2
                    safe_rect_filled(scx - gap - size - 1, scy - (thickness/2) - 1, size + 2, o_thick, outline_color)
                    safe_rect_filled(scx + gap - 1, scy - (thickness/2) - 1, size + 2, o_thick, outline_color)
                    if type == 1 then
                        safe_rect_filled(scx - (thickness/2) - 1, scy - gap - size - 1, o_thick, size + 2, outline_color)
                    end
                    safe_rect_filled(scx - (thickness/2) - 1, scy + gap - 1, o_thick, size + 2, outline_color)
                end

                safe_rect_filled(scx - gap - size, scy - (thickness/2), size, thickness, color)
                safe_rect_filled(scx + gap, scy - (thickness/2), size, thickness, color)
                if type == 1 then
                    safe_rect_filled(scx - (thickness/2), scy - gap - size, thickness, size, color)
                end
                safe_rect_filled(scx - (thickness/2), scy + gap, thickness, size, color)
            end

        elseif type == 2 then
            if outline then
                for i = 0, thickness + 1 do
                    draw.circle(scx, scy, size + 1 + (i * 0.5), outline_color, 64)
                    draw.circle(scx, scy, size + 1 - (i * 0.5), outline_color, 64)
                end
            end
            for i = 0, thickness - 1 do
                draw.circle(scx, scy, size + (i * 0.5), color, 64)
                draw.circle(scx, scy, size - (i * 0.5), color, 64)
            end

        elseif type == 3 then
            if outline then
                draw.circle_filled(scx, scy, size + 1, outline_color, 64)
            end
            draw.circle_filled(scx, scy, size, color, 64)
        elseif type == 5 then 
            local r = size
            local rot_speed_jew = settings.xhair_rotate_speed or 2.0
            local rot_jew = t * rot_speed_jew

            local function pt(angle)
                local a = angle + rot_jew
                return scx + math.cos(a) * r, scy + math.sin(a) * r
            end

            local ax, ay = pt(-math.pi / 2)
            local bx, by = pt(math.pi / 6)
            local cx2, cy2 = pt(5 * math.pi / 6)

            local dx, dy = pt(math.pi / 2)
            local ex, ey = pt(-math.pi / 6)
            local fx, fy = pt(-5 * math.pi / 6)

            if outline then
                local o_thick = thickness + 2
                draw.line(ax, ay, bx, by, outline_color, o_thick)
                draw.line(bx, by, cx2, cy2, outline_color, o_thick)
                draw.line(cx2, cy2, ax, ay, outline_color, o_thick)
                draw.line(dx, dy, ex, ey, outline_color, o_thick)
                draw.line(ex, ey, fx, fy, outline_color, o_thick)
                draw.line(fx, fy, dx, dy, outline_color, o_thick)
            end

            draw.line(ax, ay, bx, by, color, thickness)
            draw.line(bx, by, cx2, cy2, color, thickness)
            draw.line(cx2, cy2, ax, ay, color, thickness)
            draw.line(dx, dy, ex, ey, color, thickness)
            draw.line(ex, ey, fx, fy, color, thickness)
            draw.line(fx, fy, dx, dy, color, thickness)
        elseif type == 6 then 
            local half = size
            local rot_speed_hit = settings.xhair_rotate_speed or 2.0
            local ca, sa = math.cos(t * rot_speed_hit), math.sin(t * rot_speed_hit)

            local function rp(lx, ly)
                return scx + lx*ca - ly*sa, scy + lx*sa + ly*ca
            end

            
            local ccx, ccy = rp(0, 0)
            
            
            local tmx, tmy = rp(0, -half) 
            local rmx, rmy = rp(half, 0)  
            local bmx, bmy = rp(0, half)  
            local lmx, lmy = rp(-half, 0) 


            local trx, try = rp(half, -half) 
            local brx, bry = rp(half, half)  
            local blx, bly = rp(-half, half) 
            local tlx, tly = rp(-half, -half) 
            if outline then
                local ot = thickness + 2
                
                draw.line(ccx, ccy, tmx, tmy, outline_color, ot)
                draw.line(ccx, ccy, rmx, rmy, outline_color, ot)
                draw.line(ccx, ccy, bmx, bmy, outline_color, ot)
                draw.line(ccx, ccy, lmx, lmy, outline_color, ot)
                
                draw.line(tmx, tmy, trx, try, outline_color, ot)
                draw.line(rmx, rmy, brx, bry, outline_color, ot)
                draw.line(bmx, bmy, blx, bly, outline_color, ot)
                draw.line(lmx, lmy, tlx, tly, outline_color, ot)
            end

            
            draw.line(ccx, ccy, tmx, tmy, color, thickness)
            draw.line(ccx, ccy, rmx, rmy, color, thickness)
            draw.line(ccx, ccy, bmx, bmy, color, thickness)
            draw.line(ccx, ccy, lmx, lmy, color, thickness)
            
            draw.line(tmx, tmy, trx, try, color, thickness)
            draw.line(rmx, rmy, brx, bry, color, thickness)
            draw.line(bmx, bmy, blx, bly, color, thickness)
            draw.line(lmx, lmy, tlx, tly, color, thickness)
        end
    end

