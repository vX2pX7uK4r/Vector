    local function find_first_part(model)
        if not model then return nil end
        local class = model.ClassName
        if class == "Part" or class == "MeshPart" then
            return model
        end
        local children = model:GetChildren()
        for i = 1, #children do
            local found = find_first_part(children[i])
            if found then return found end
        end
        return nil
    end

