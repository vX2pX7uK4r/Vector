    local function debug_execute_command(cmd)
        local now = tick()
        
        if #debug_command_history > 0 then
            local last_cmd = debug_command_history[#debug_command_history]
            if now - last_cmd.time < 1000 then
                print(debug_prefix .. "Command rate limited, wait 1 second")
                return
            end
        end
        
        debug_command_history[#debug_command_history + 1] = {time = now, cmd = cmd}
        
        if cmd == "stats" then
            debug_print_stats()
        elseif cmd == "refresh" then
            print(debug_prefix .. "Manual refresh triggered")
            refresh_game_folders()
            scan_world()
            scan_loot()
            scan_npcs()
            scan_base()
        elseif cmd == "toggle" then
            debug_window_open = not debug_window_open
            print(debug_prefix .. "Debug window: " .. (debug_window_open and "ON" or "OFF"))
        elseif cmd == "help" then
            print(debug_prefix .. "Commands: stats, refresh, toggle, help")
        else
            print(debug_prefix .. "Unknown command. Use 'help' for list")
        end
    end

