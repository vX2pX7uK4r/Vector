    local function debug_log(msg)
        if not DEBUG_MODE then return end
        
        local now = tick()
        debug_buffer[#debug_buffer + 1] = {
            time = now,
            msg = msg
        }
        
        if #debug_buffer > 50 then
            debug_flush_logs()
        end
    end

    local function debug_flush_logs()
        if not DEBUG_MODE or #debug_buffer == 0 then return end
        
        local now = tick()
        if now - debug_last_flush < debug_flush_interval then return end
        
        debug_last_flush = now
        
        local grouped_logs = {}
        for i = 1, #debug_buffer do
            local log = debug_buffer[i]
            local msg = log.msg
            
            if not grouped_logs[msg] then
                grouped_logs[msg] = 0
            end
            grouped_logs[msg] = grouped_logs[msg] + 1
        end
        
        for msg, count in pairs(grouped_logs) do
            if count > 1 then
                print(debug_prefix .. msg .. " (x" .. count .. ")")
            else
                print(debug_prefix .. msg)
            end
        end
        
        debug_buffer = {}
    end

    local function debug_update_stat(category, count)
        if not DEBUG_MODE then return end
        
        debug_stats[category] = {
            count = count,
            last_update = tick()
        }
    end

    local function debug_print_stats()
        if not DEBUG_MODE then return end
        
        print(debug_prefix .. "=== STATISTICS ===")
        for category, data in pairs(debug_stats) do
            print(string.format("%s: %d (updated %dms ago)", 
                category, data.count, tick() - data.last_update))
        end
        print(debug_prefix .. string.format("Camera: (%.1f, %.1f, %.1f)", 
            cached_data.camera_x, cached_data.camera_y, cached_data.camera_z))
    end

