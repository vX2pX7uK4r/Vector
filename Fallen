    local function get_distance(x1, y1, z1, x2, y2, z2)
        local dx = x1 - (x2 or 0)
        local dy = y1 - (y2 or 0)
        local dz = z1 - (z2 or 0)
        return sqrt(dx * dx + dy * dy + dz * dz)
    end

    local function get_nearest_location(x, y, z)
        local nodes = game.Workspace:FindFirstChild("Nodes")
        if not nodes then return "Unknown" end
        
        local nearest_name = "Unknown"
        local min_dist = 999999
        
        local children = nodes:GetChildren()
        for i = 1, #children do
            local node = children[i]
            if node and node:IsA("BasePart") then
                local pos = node.Position
                local d = get_distance(x, y, z, pos.X, pos.Y, pos.Z)
                if d < min_dist then
                    min_dist = d
                    nearest_name = node.Name
                end
            end
        end
        
        return nearest_name
    end

