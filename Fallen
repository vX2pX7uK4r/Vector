    local function process_base_children(container, parts, type_name)
        if not container then return end
        local function add_part(p)
            if not p then return end
            local size, pos, rv, uv, lv = nil, nil, nil, nil, nil
            local ok_data = pcall(function()
                size = p.Size
                pos = p.Position
                rv = p.RightVector
                uv = p.UpVector
                lv = p.LookVector
            end)
            
            if ok_data and size and pos and rv and uv and lv then
                parts[#parts + 1] = {
                    x = pos.X, y = pos.Y, z = pos.Z,
                    hx = size.X * 0.5,
                    hy = size.Y * 0.5,
                    hz = size.Z * 0.5,
                    rx = rv.X, ry = rv.Y, rz = rv.Z,
                    ux = uv.X, uy = uv.Y, uz = uv.Z,
                    lx = lv.X, ly = lv.Y, lz = lv.Z
                }
            end
        end

        
        local container_class = ""
        pcall(function() container_class = container.ClassName end)

        if container:IsA("Model") then
            
            local c_name = ""
            pcall(function() c_name = container.Name end)
            
            if BASE_MAP[c_name] then
                local main = container:FindFirstChild("Main") or container:FindFirstChild("PrimaryPart") or find_first_part(container)
                if main then
                    add_part(main)
                    return
                end
            end
        elseif container:IsA("BasePart") then
            local c_name = ""
            pcall(function() c_name = container.Name end)
            if BASE_MAP[c_name] then
                add_part(container)
                return
            end
        end

        
        local ok, children = pcall(function() return container:GetChildren() end)
        if not ok or not children then return end
        
        for i = 1, #children do
            local child = children[i]
            if not child then goto next_child end
            
            local child_name = ""
            pcall(function() child_name = child.Name end)
            
            if child:IsA("Model") then
                local main = child:FindFirstChild("Main") or child:FindFirstChild("PrimaryPart") or find_first_part(child)
                if main then add_part(main) end
            elseif child:IsA("BasePart") then
                add_part(child)
            end
            ::next_child::
        end
    end

    local function scan_base()
        if not settings.base_enabled then
            cached_data.base = {}
            return
        end
        
        if not refresh_game_folders() or not game_folders.bases then
            cached_data.base = {}
            return
        end
        
        local result = {}
        local bases_children = nil
        pcall(function() bases_children = game_folders.bases:GetChildren() end)
        
        if not bases_children then
            cached_data.base = {}
            return
        end
        
        for j = 1, #bases_children do
            local bases_child = bases_children[j]
            if not bases_child or bases_child.Name == "Loners" then goto continue_bases end
            
            local ok3, base_children = pcall(function() return bases_child:GetChildren() end)
            if not ok3 or not base_children then goto continue_bases end
            

            
            local items_to_process = {}
            local bases_child_name = nil
            pcall(function() bases_child_name = bases_child.Name end)
            
            if bases_child_name and BASE_MAP[bases_child_name] then
            
                table.insert(items_to_process, bases_child)
            else
            
                for k = 1, #base_children do
                    table.insert(items_to_process, base_children[k])
                end
            end
            
            for k = 1, #items_to_process do
                local type_folder = items_to_process[k]
                if not type_folder then goto continue_type end
                
                local type_name = nil
                pcall(function() type_name = type_folder.Name end)
                if not type_name or type_name == "" then goto continue_type end
                
                local base_key = BASE_MAP[type_name]
                if not base_key or not settings[base_key] then goto continue_type end
                
                local parts = {}
                
                if type_name == "Sleeping Bag" then
                    local sleeping_bag_model = type_folder:FindFirstChild("SleepingBag") or type_folder:FindFirstChild("Sleeping_Bag")
                    if not sleeping_bag_model then
                        local children = nil
                        pcall(function() children = type_folder:GetChildren() end)
                        if children then
                            for _, child in ipairs(children) do
                                if child.ClassName == "Model" then
                                    sleeping_bag_model = child
                                    break
                                end
                            end
                        end
                    end
                    
                    if sleeping_bag_model then
                        if settings.filter_own_bags then
                            local lp = game.LocalPlayer
                            if lp then
                                local is_own = false
                                pcall(function()
                                    if sleeping_bag_model.OwnerAddress == lp.Address then is_own = true end
                                    if not is_own and sleeping_bag_model:FindFirstChild("OwnerID") then
                                        local oid = sleeping_bag_model.OwnerID
                                        if oid == lp.UserId or oid == lp.Address then is_own = true end
                                    end
                                end)
                                if is_own then goto continue_type end
                            end
                        end

                        local main_part = sleeping_bag_model:FindFirstChild("Main")
                        if not main_part then
                            local children = nil
                            pcall(function() children = sleeping_bag_model:GetChildren() end)
                            if children then
                                for _, child in ipairs(children) do
                                    if child.ClassName == "MeshPart" or child.ClassName == "Part" then
                                        main_part = child
                                        break
                                    end
                                end
                            end
                        end
                        
                        if main_part then
                            local size, pos, rv, uv, lv = nil, nil, nil, nil, nil
                            pcall(function()
                                size = main_part.Size
                                pos = main_part.Position
                                rv = main_part.RightVector
                                uv = main_part.UpVector
                                lv = main_part.LookVector
                            end)
                            
                            if size and pos and rv and uv and lv then
                                parts[#parts + 1] = {
                                    x = pos.X, y = pos.Y, z = pos.Z,
                                    hx = size.X * 0.5,
                                    hy = size.Y * 0.5,
                                    hz = size.Z * 0.5,
                                    rx = rv.X, ry = rv.Y, rz = rv.Z,
                                    ux = uv.X, uy = uv.Y, uz = uv.Z,
                                    lx = lv.X, ly = lv.Y, lz = lv.Z
                                }
                            end
                        end
                    end
                else
                    pcall(function() process_base_children(type_folder, parts, type_name) end)
                end
                
                if #parts > 0 then
                    result[#result + 1] = {
                        name = type_name,
                        parts = parts,
                        color_key = base_key
                    }
                end
                
                ::continue_type::
            end
            ::continue_bases::
        end
        
        cached_data.base = result
    end

