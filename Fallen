    local function _isfile(path)
        if isfile then 
            local ok, res = pcall(function() return isfile(path) end)
            if ok then return res end
        end
        local f = io.open(path, "r")
        if f then f:close() return true end
        return false
    end

    local function _readfile(path)
        if readfile then
            local ok, res = pcall(function() return readfile(path) end)
            if ok then return res end
        end
        local f = io.open(path, "r")
        if f then
            local content = f:read("*all")
            f:close()
            return content
        end
        return ""
    end

    local function _writefile(path, content)
        if writefile then
            local ok, err = pcall(function() writefile(path, content) end)
            if ok then return true end
        end
        local f = io.open(path, "w")
        if f then
            f:write(content)
            f:close()
            return true
        end
        return false
    end

    local function _delfile(path)
        if delfile then
            pcall(function() delfile(path) end)
            return
        end
        if os.remove then
            pcall(function() os.remove(path) end)
        end
    end

    local function save_config(name)
        local path = get_config_path(name)
        local content = ""
        

        if _isfile(path) then
            local old_content = _readfile(path)
            local custom_name = old_content:match("config_custom_name=([^\n\r]+)")
            if custom_name then
                content = content .. "config_custom_name=" .. custom_name .. "\n"
            end
        end

        for _, item in ipairs(SAVE_ITEMS) do
            local id = item.id
            local val = menu.get(id)
            if item.type == "bool" then
                content = content .. string.format("%s=%s\n", id, val and "1" or "0")
            elseif item.type == "int" then
                content = content .. string.format("%s=%d\n", id, val or 0)
            elseif item.type == "string" then
                content = content .. string.format("%s=%s\n", id, tostring(val or ""))
            end
            if item.color then
                local c = menu.get_color(id)
                if c then
                    content = content .. string.format("%s_color=%.4f,%.4f,%.4f,%.4f\n", id, c[1], c[2], c[3], c[4])
                end
            end
            if item.key then
                local k = menu.get_key(id)
                content = content .. string.format("%s_key=%d\n", id, k or 0)
            end
        end
        
        local success = _writefile(path, content)
        
        if success then
            safe_notify("Config saved successfully!")
            print("[Fallen] Config saved to " .. path)
        else
            safe_notify("Failed to save config!", "danger")
            print("[Fallen] Failed to save config: " .. tostring(path))
        end
        return success
    end

    local function load_config(name)
        local path = get_config_path(name)
        
        local exists = _isfile(path)
        
        if not exists then
            safe_notify("No saved config found!", "warning")
            return false
        end
        
        local content = _readfile(path)
        
        if content == "" then
            safe_notify("Failed to read config!", "danger")
            return false
        end
        
        local data = {}
        for line in content:gmatch("[^\r\n]+") do
            local key, value = line:match("^([^=]+)=(.+)$")
            if key and value then
                data[key] = value
            end
        end
        
        for _, item in ipairs(SAVE_ITEMS) do
            local id = item.id
            if data[id] then
                if item.type == "bool" then
                    menu.set(id, data[id] == "1")
                elseif item.type == "int" then
                    menu.set(id, tonumber(data[id]) or 0)
                elseif item.type == "string" then
                    menu.set(id, data[id])
                end
            end
            if item.color and data[id .. "_color"] then
                local r, g, b, a = data[id .. "_color"]:match("([%d%.%-]+),([%d%.%-]+),([%d%.%-]+),([%d%.%-]+)")
                if r then
                    menu.set_color(id, { tonumber(r), tonumber(g), tonumber(b), tonumber(a) })
                end
            end
            if item.key and data[id .. "_key"] then
                menu.set_key(id, tonumber(data[id .. "_key"]) or 0)
            end
        end
        
        if type(cache_settings) == "function" then
            cache_settings()
        end
        
        safe_notify("Config loaded successfully!")
        print("[Fallen] Config loaded from " .. path)
        return true
    end

    function safe_notify(msg, n_type, bypass_dup)
        if not msg then return end
        local m = tostring(msg)
        local nt = n_type or "info" 
        
        
        local global_notify = _G.safe_notify
        if global_notify and global_notify ~= safe_notify then
            local ok, err = pcall(function() global_notify(m, nt) end)
            if ok then return end
        end

        
        if not notifications then notifications = {} end

        if not bypass_dup then
            for _, n in ipairs(notifications) do
                if n.msg == m and (tick() - n.time) < 5000 then
                    return
                end
            end
        end

        local duration = (settings and settings.notify_duration) or 5000

        table.insert(notifications, {
            msg = m,
            time = tick(),
            duration = duration,
            alpha = 0,
            x_offset = 100, 
            current_y = 0,
            type = nt
        })
        
        if #notifications > 8 then
            table.remove(notifications, 1)
        end

        if menu and menu.notify then
            menu.notify(m)
        end
        
        print(string.format("[FALLEN-NOTIFY - %s] %s", nt:upper(), m))
    end

