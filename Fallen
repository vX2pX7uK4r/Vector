        local cam_y = cached_data.camera_y
        local cam_z = cached_data.camera_z
        for i = 1, #players do
            local player = players[i]
            if not player or player.ClassName ~= "Player" then goto continue_player end
            
            if player == local_player then goto continue_player end
            
            local character = nil
            pcall(function() character = player.Character end)
            if not character then goto continue_player end
            
            local head = character:FindFirstChild("Head")
            local humanoid = character:FindFirstChild("Humanoid")
            local root_part = character:FindFirstChild("HumanoidRootPart")
            if not head then goto continue_player end
            
            local head_pos = nil
            pcall(function() head_pos = head.Position end)
            if not head_pos then goto continue_player end
            
            local px, py, pz = 0, 0, 0
            local ok_pos = pcall(function() px, py, pz = head_pos.X, head_pos.Y, head_pos.Z end)
            if not ok_pos then goto continue_player end
            
            local display_name = "Unknown"
            pcall(function() 
                local d_name = player.DisplayName
                local s_name = player.Name
                if d_name and d_name ~= "" and d_name:find("%w") then
                    display_name = d_name
                elseif s_name and s_name ~= "" and s_name:find("%w") then
                    display_name = s_name
                end
            end)
            
            
            if display_name == "Unknown" or display_name == "" or not display_name:find("%w") then
                pcall(function()
                    local s_name = player.Name
                    if s_name and s_name ~= "" then
                        display_name = s_name
                    else
                        display_name = "Player_" .. tostring(player.UserId):sub(-4)
                    end
                end)
            end

            
            local player_id = player.UserId or player.Name or display_name
            if player_id and cached_data.player_health_history[player_id] == nil then
                if humanoid then
                    pcall(function() cached_data.player_health_history[player_id] = humanoid.Health end)
                end
            end
            
            local dist = get_distance(px, py, pz, cam_x, cam_y, cam_z)
            local held_item = nil
            local is_vip = false
            
            
            pcall(function()
                if player.MembershipType == Enum.MembershipType.Premium then
                    is_vip = true
                elseif player:GetAttribute("VIP") or player:GetAttribute("IsVIP") or character:GetAttribute("VIP") or character:GetAttribute("IsVIP") then
                    is_vip = true
                elseif player:FindFirstChild("VIP") or character:FindFirstChild("VIP") or player:FindFirstChild("IsVIP") then
                    is_vip = true
                elseif player:FindFirstChild("leaderstats") and (player.leaderstats:FindFirstChild("VIP") or player.leaderstats:FindFirstChild("IsVIP")) then
                    local ls_vip = player.leaderstats:FindFirstChild("VIP") or player.leaderstats:FindFirstChild("IsVIP")
                    if ls_vip and (ls_vip:IsA("BoolValue") or ls_vip:IsA("StringValue")) and (ls_vip.Value == true or ls_vip.Value == "Yes" or ls_vip.Value == "VIP") then
                        is_vip = true
                    end
                end
            end)

            local clothing = {}
            local seen_clothing = {}
            local parts = {}
            
            local ok2, char_children = pcall(function() return character:GetChildren() end)
            if ok2 and char_children then
                for j = 1, #char_children do
                    local child = char_children[j]
                    if not child then goto continue_child end
                    
                    local child_name = nil
                    pcall(function() child_name = child.Name end)
                    if not child_name then goto continue_child end
                    
                    if not held_item and WEAPON_ITEMS[child_name] then
                        held_item = child_name
                    end
                    if find(child_name, "Armor") then
                        local armor_id = child_name:match("^(.-)/") or child_name
                        armor_id = armor_id:gsub(" ", "_")
                        local armor_name = ARMOR_MAP[armor_id]
                        if armor_name and not seen_clothing[armor_name] then
                            seen_clothing[armor_name] = true
                            clothing[#clothing + 1] = armor_name
                        end
                    end
                    if BODY_PARTS[child_name] then
                        local p_size, rv, uv, lv = nil, nil, nil, nil
                        pcall(function()
                            p_size = child.Size
                            rv = child.RightVector
                            uv = child.UpVector
                            lv = child.LookVector
                        end)
                        if p_size and rv and uv and lv then
                            local sx, sy, sz = 0, 0, 0
                            local rvx, rvy, rvz = 0, 0, 0
                            local uvx, uvy, uvz = 0, 0, 0
                            local lvx, lvy, lvz = 0, 0, 0
                            
                            local ok_parts = pcall(function()
                                sx, sy, sz = p_size.X, p_size.Y, p_size.Z
                                rvx, rvy, rvz = rv.X, rv.Y, rv.Z
                                uvx, uvy, uvz = uv.X, uv.Y, uv.Z
                                lvx, lvy, lvz = lv.X, lv.Y, lv.Z
                            end)
                            
                            if ok_parts then
                                parts[child_name] = {
                                    part = child,
                                    hx = sx * 0.5,
                                    hy = sy * 0.5,
                                    hz = sz * 0.5,
                                    rx = rvx, ry = rvy, rz = rvz,
                                    ux = uvx, uy = uvy, uz = uvz,
                                    lx = lvx, ly = lvy, lz = lvz
                                }
                            end
                        end
                    end
                    ::continue_child::
                end
            end
            result[#result + 1] = {
                name = display_name,
                UserId = player.UserId,
                head = head,
                head_x = px,
                head_y = py,
                head_z = pz,
                dist = dist,
                held_item = held_item,
                is_vip = is_vip,
                clothing = clothing,
                humanoid = humanoid,
                root_part = root_part,
                parts = parts,
                obj = character
            }
            ::continue_player::
        end
        cached_data.players = result
        cached_data.inventory = result
    end

    local function process_raid_explosion(explosion_type, explosion_pos)
        if not explosion_pos then return end
        
        local type_str = tostring(explosion_type):lower()
        local is_raid = false
        local display_name = "Explosion"
        
        
        for k, v in pairs(RAID_BOOM) do
            if type_str:find(k:lower()) then
                is_raid = true
                display_name = v.name
                break
            end
        end
        
        if not is_raid and (type_str:find("explosion") or type_str:find("boom") or type_str:find("rocket") or type_str:find("c4") or type_str:find("charge")) then
            is_raid = true
        end

        if not is_raid then 
            return 
        end
        
        local pos = explosion_pos
        local now = tick()
        
        if DEBUG_MODE then
            print(string.format("[FALLEN] RAID DETECTED: %s at %s", type_str, tostring(pos)))
        end
        
        if settings.raid_esp_enabled then
            local best, best_dist = nil, 50 
            for _, cl in ipairs(cached_data.raids) do
                local dist = (pos - cl.center).Magnitude
                if dist < best_dist then
                    best, best_dist = cl, dist
                end
            end
            
            if best then
                table.insert(best.items, { pos = pos, type = explosion_type })
                best.sum = best.sum + pos
                best.count = best.count + 1
                best.center = best.sum / best.count
                best.last_update = now
            else
                table.insert(cached_data.raids, {
                    items = { { pos = pos, type = explosion_type } },
                    sum = pos,
                    count = 1,
                    center = pos,
                    last_update = now
                })
            end
        end
        
        if settings.raid_notifications then
            safe_notify(string.format("raid start at position %.0f, %.0f, %.0f", pos.X, pos.Y, pos.Z), "warning")
        end
    end

    local function scan_raids()
        if not settings.raid_esp_enabled then 
            cached_data.projectiles = {}
            return 
        end
        
        local ws = game:GetService("Workspace") or game.Workspace or workspace
        if not ws then return end
        
        local search_targets = {}
        local vfx = ws:FindFirstChild("VFX")
        if vfx then table.insert(search_targets, vfx) end
        table.insert(search_targets, ws)
        
        local now = tick()
        local new_projectiles = {}
        
        
        if now % 10 < 0.1 then
            for obj, time in pairs(processed_explosions) do
                if now - time > 30 then processed_explosions[obj] = nil end
            end
        end
        
        local keywords = {"explosion", "boom", "rocket", "charge", "c4", "projectile", "grenade", "bomb", "shell"}
        
        for _, container in ipairs(search_targets) do
            local children = nil
            pcall(function() children = container:GetChildren() end)
            
            if children then
                for i = 1, #children do
                    local child = children[i]
                    if child then
                        local name = tostring(child.Name):lower()
                        local is_match = false
                        
                        if child:IsA("Explosion") then
                            is_match = true
                        else
                            for _, kw in ipairs(keywords) do
                                if name:find(kw) then
                                    is_match = true
                                    break
                                end
                            end
                        end
                        
                        if is_match then
                            local pos = nil
                            pcall(function()
                                if child:IsA("BasePart") or child:IsA("Explosion") then
                                    pos = child.Position
                                elseif child:IsA("Model") then
                                    pos = child.PrimaryPart and child.PrimaryPart.Position or child:GetModelCFrame().Position
                                end
                            end)
                            
                            if pos then
                                
                                if not processed_explosions[child] then
                                    processed_explosions[child] = now
                                    process_raid_explosion(child.Name, pos)
                                end
                                
                                
                                table.insert(new_projectiles, {
                                    name = child.Name,
                                    pos = pos,
                                    obj = child
                                })
                            end
                        end
                    end
                end
            end
        end
        cached_data.projectiles = new_projectiles
    end

    local function initialize_raid_detection()
        if DEBUG_MODE then print("[FALLEN] Initializing Raid Detection...") end
        local ws = game:GetService("Workspace") or game.Workspace or workspace
        local rs = game:GetService("ReplicatedStorage") or game.ReplicatedStorage
        
        if not ws then 
            if DEBUG_MODE then print("[FALLEN] Could not access Workspace") end
            return 
        end

    
        local Modules = rs and rs:FindFirstChild("Modules")
        if Modules then
            local VFXModule = Modules:FindFirstChild("VFXModule")
            if VFXModule then
                local VFX = nil
                local success, err = pcall(function()
                    VFX = require(VFXModule)
                end)
                
                if success and VFX and VFX.CreateExplosion then 
                    local old_create_explosion = VFX.CreateExplosion
                    VFX.CreateExplosion = function(...)
                        local args = {...}
                        local explosion_type = tostring(args[5] or "Explosion")
                        local explosion_cf = args[2]
                        
                        local pos = nil
                        if typeof(explosion_cf) == "CFrame" then
                            pos = explosion_cf.Position
                        elseif typeof(explosion_cf) == "Vector3" then
                            pos = explosion_cf
                        elseif typeof(args[1]) == "Vector3" then 
                            pos = args[1]
                        elseif typeof(args[1]) == "CFrame" then
                            pos = args[1].Position
                        end
                        
                        if pos then
                            process_raid_explosion(explosion_type, pos)
                        end
                        
                        return old_create_explosion(...)
                    end
                    if DEBUG_MODE then print("[FALLEN] Successfully hooked VFXModule") end
                end
            end
        end
        
        
        local vfx_folder = ws:FindFirstChild("VFX") or (rs and rs:FindFirstChild("VFX"))
        if not vfx_folder then
            local children = ws:GetChildren()
            for i = 1, #children do
                local child = children[i]
                if child.Name == "VFX" and (child:IsA("Folder") or child:IsA("Model")) then
                    vfx_folder = child
                    break
                end
            end
        end
        
        if vfx_folder then
            pcall(function()
                if vfx_folder.ChildAdded then
                    vfx_folder.ChildAdded:Connect(function(child)
                        local name = tostring(child.Name):lower()
                        if name:find("explosion") or name:find("boom") or name:find("rocket") or name:find("charge") or name:find("projectile") or name:find("grenade") or name:find("shell") then
                            
                            local pos = nil
                            if child:IsA("BasePart") or child:IsA("Explosion") then
                                pos = child.Position
                            elseif child:IsA("Model") then
                                pos = child.PrimaryPart and child.PrimaryPart.Position or child:GetModelCFrame().Position
                            end
                            
                            if pos then
                                process_raid_explosion(child.Name, pos)
                            end
                        end
                    end)
                end
            end)
        end

        
        pcall(function()
            ws.DescendantAdded:Connect(function(desc)
                local name = ""
                local ok = pcall(function() name = tostring(desc.Name):lower() end)
                if ok and (name:find("explosion") or name:find("boom") or name:find("rocket") or name:find("charge") or name:find("projectile") or name:find("grenade") or name:find("shell")) then
                    
                    local pos = nil
                    pcall(function()
                        if desc:IsA("BasePart") or desc:IsA("Explosion") then
                            pos = desc.Position
                        elseif desc:IsA("Model") then
                            pos = desc.PrimaryPart and desc.PrimaryPart.Position or desc:GetModelCFrame().Position
                        end
                    end)
                    
                    if pos then
                        process_raid_explosion(desc.Name, pos)
                    end
                end
            end)
        end)
    end

    local function scan_mods()
        if not settings or not settings.mod_detector_enabled then
            cached_data.mods = {}
            cached_data.notified_mods = {} 
            return
        end
        
        local players = {}
        local players_service = game:GetService("Players")
        
        local success, err = pcall(function() players = players_service:GetPlayers() end)
        if not success or #players == 0 then
            pcall(function() players = players_service:GetChildren() end)
        end
        
        local result = {}
        local current_mod_ids = {} 
        
        if DEBUG_MODE then
            print(string.format("[MOD DETECTOR] Scanning %d potential players...", #players))
        end
        
        for i = 1, #players do
            local p = players[i]
            if p and (p:IsA("Player") or p.ClassName == "Player") then
                local pid = tonumber(p.UserId)
                
                if not pid and p.UserId then
                    pid = tonumber(tostring(p.UserId):match("%d+"))
                end
                
                if pid then
                    local sid = tostring(pid)
                    local is_mod = false
                    
                    if target_set[pid] or target_set[sid] then
                        is_mod = true
                    end

                    if is_mod then
                        current_mod_ids[pid] = true
                        
                        local role = "MOD"
                        local name = "Unknown"
                        
                        pcall(function() 
                            if p.DisplayName and p.DisplayName ~= "" then
                                name = p.DisplayName
                            elseif p.Name and p.Name ~= "" then
                                name = p.Name
                            end
                        end)
                        
                        if name == "Unknown" or name == "" then
                            pcall(function()
                                name = p.Name or tostring(p) or "Unknown"
                            end)
                        end
                        if not name or name == "" then name = "Unknown" end
                        
                        if not cached_data.notified_mods[pid] then
                            local msg = string.format("MOD: %s", name)
                            
                            print(string.format("[MOD DETECTOR] MOD: %s (ID: %s)", name, tostring(pid)))
                            
                            safe_notify(msg, "warning")
                            cached_data.notified_mods[pid] = true
                        end
                        
                        table.insert(result, {
                            name = name,
                            id = pid,
                            role = role
                        })
                    end
                end
            end
        end
        
        for pid, _ in pairs(cached_data.notified_mods) do
            if not current_mod_ids[pid] then
                cached_data.notified_mods[pid] = nil
            end
        end
        
        cached_data.mods = result
    end

