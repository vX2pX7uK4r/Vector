    local slot_display_names = {"Slot 1", "Slot 2", "Slot 3", "Slot 4", "Slot 5"}
    
    local function update_slot_names()
        for i = 1, 5 do
            local name = "Fallen_Config_Slot_" .. i .. ".txt"
            local path = get_config_path(name)
            if _isfile(path) then
                local content = _readfile(path)
                local custom_name = content:match("config_custom_name=([^\n\r]+)")
                if custom_name then
                    slot_display_names[i] = custom_name
                else
                    slot_display_names[i] = "Slot " .. i
                end
            else
                slot_display_names[i] = "Slot " .. i
            end
        end
    end

    local function rename_config_with_input(slot)
        local Instance = get_rbx_global("Instance")
        local UDim2 = get_rbx_global("UDim2")
        local Color3 = get_rbx_global("Color3")
        local Enum = get_rbx_global("Enum")

        local name = "Fallen_Config_Slot_" .. slot .. ".txt"
        local path = get_config_path(name)

        
        local function cycle_rename()
            local names = {"Legit", "Rage", "HvH", "Main", "Alt", "Test", "Semi", "Farm", "Raid", "War"}
            local current_name = "Slot " .. slot
            if _isfile(path) then
                local content = _readfile(path)
                current_name = content:match("config_custom_name=([^\n\r]+)") or current_name
            end
            
            local next_idx = 1
            for i, n in ipairs(names) do
                if n == current_name then
                    next_idx = (i % #names) + 1
                    break
                end
            end
            
            local new_name = names[next_idx]
            local content = ""
            if _isfile(path) then
                content = _readfile(path)
                if content:find("config_custom_name=") then
                    content = content:gsub("config_custom_name=[^\n\r]+", "config_custom_name=" .. new_name)
                else
                    content = "config_custom_name=" .. new_name .. "\n" .. content
                end
            else
                content = "config_custom_name=" .. new_name .. "\n"
            end
            _writefile(path, content)
            update_slot_names()
            safe_notify("Renamed Slot " .. slot .. " to: " .. new_name .. " (Cycle Mode)", "success")
        end

        
        local function clipboard_rename()
            local set_clipboard = (getgenv and getgenv().set_clipboard) or set_clipboard or (syn and syn.write_clipboard)
            if not set_clipboard then
                cycle_rename() 
                return
            end
            
            safe_notify("Enter the name in your clipboard and click Rename again (Fallback mode)", "warning")
            local current = ""
            pcall(function() current = get_clipboard() or "" end)
            
            if current ~= "" and current ~= "Enter Name Here" then
                local new_name = current:gsub("[^%w%s%-_]", ""):sub(1, 20)
                local content = ""
                if _isfile(path) then
                    content = _readfile(path)
                    if content:find("config_custom_name=") then
                        content = content:gsub("config_custom_name=[^\n\r]+", "config_custom_name=" .. new_name)
                    else
                        content = "config_custom_name=" .. new_name .. "\n" .. content
                    end
                else
                    content = "config_custom_name=" .. new_name .. "\n"
                end
                _writefile(path, content)
                update_slot_names()
                safe_notify("Renamed Slot " .. slot .. " to: " .. new_name .. " (via Clipboard)", "success")
            else
                set_clipboard("Enter Name Here")
            end
        end

        if not Instance or not UDim2 or not Color3 or not Enum then
            clipboard_rename()
            return
        end

       
        local gui_parent
        pcall(function()
            local game_obj = get_rbx_global("game")
            local CoreGui = game_obj:GetService("CoreGui")
            gui_parent = (gethui and gethui()) or CoreGui
        end)
        
        if not gui_parent then
            pcall(function()
                gui_parent = get_rbx_global("game"):GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
            end)
        end

        if not gui_parent then
            clipboard_rename()
            return
        end
        
        local sg
        local success_sg = pcall(function()
            sg = Instance.new("ScreenGui")
            sg.Name = "FallenRenamePrompt"
            sg.DisplayOrder = 999
            sg.ResetOnSpawn = false
            sg.Parent = gui_parent
        end)

        if not success_sg or not sg then
            clipboard_rename()
            return
        end
        
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(0, 300, 0, 110)
        frame.Position = UDim2.new(0.5, -150, 0.5, -55)
        frame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        frame.BorderSizePixel = 0
        frame.Active = true
        frame.Draggable = true
        frame.Parent = sg

        local stroke = Instance.new("UIStroke")
        stroke.Thickness = 1
        stroke.Color = Color3.fromRGB(60, 60, 60)
        stroke.Parent = frame
        
        local title = Instance.new("TextLabel")
        title.Size = UDim2.new(1, 0, 0, 30)
        title.Text = "Rename Config Slot " .. slot
        title.TextColor3 = Color3.new(1, 1, 1)
        title.TextSize = 14
        title.Font = Enum.Font.SourceSansBold
        title.BackgroundTransparency = 1
        title.Parent = frame
        
        local textbox = Instance.new("TextBox")
        textbox.Size = UDim2.new(0.9, 0, 0, 30)
        textbox.Position = UDim2.new(0.05, 0, 0.35, 0)
        textbox.PlaceholderText = "Enter new name..."
        textbox.Text = ""
        textbox.TextColor3 = Color3.new(1, 1, 1)
        textbox.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        textbox.BorderSizePixel = 0
        textbox.TextSize = 14
        textbox.Font = Enum.Font.SourceSans
        textbox.Parent = frame

        local ok_btn = Instance.new("TextButton")
        ok_btn.Size = UDim2.new(0.4, 0, 0, 30)
        ok_btn.Position = UDim2.new(0.05, 0, 0.68, 0)
        ok_btn.Text = "Save"
        ok_btn.TextColor3 = Color3.new(1, 1, 1)
        ok_btn.BackgroundColor3 = Color3.fromRGB(50, 80, 50)
        ok_btn.BorderSizePixel = 0
        ok_btn.Font = Enum.Font.SourceSansBold
        ok_btn.Parent = frame
        
        local cancel_btn = Instance.new("TextButton")
        cancel_btn.Size = UDim2.new(0.4, 0, 0, 30)
        cancel_btn.Position = UDim2.new(0.55, 0, 0.68, 0)
        cancel_btn.Text = "Cancel"
        cancel_btn.TextColor3 = Color3.new(1, 1, 1)
        cancel_btn.BackgroundColor3 = Color3.fromRGB(80, 50, 50)
        cancel_btn.BorderSizePixel = 0
        cancel_btn.Font = Enum.Font.SourceSansBold
        cancel_btn.Parent = frame
        
        local function finish(new_name)
            if new_name and new_name ~= "" then
                new_name = new_name:gsub("[^%w%s%-_]", ""):sub(1, 20)
                local content = ""
                if _isfile(path) then
                    content = _readfile(path)
                    if content:find("config_custom_name=") then
                        content = content:gsub("config_custom_name=[^\n\r]+", "config_custom_name=" .. new_name)
                    else
                        content = "config_custom_name=" .. new_name .. "\n" .. content
                    end
                else
                    content = "config_custom_name=" .. new_name .. "\n"
                end
                _writefile(path, content)
                update_slot_names()
                safe_notify("Renamed Slot " .. slot .. " to: " .. new_name .. ". Reload script to see UI label change.", "success")
            end
            sg:Destroy()
        end
        
        ok_btn.MouseButton1Click:Connect(function()
            finish(textbox.Text)
        end)
        
        cancel_btn.MouseButton1Click:Connect(function()
            finish(nil)
        end)
        
        textbox.FocusLost:Connect(function(enter)
            if enter then
                finish(textbox.Text)
            end
        end)
        
        textbox:CaptureFocus()
    end

    --// Config
        update_slot_names()

        menu.add_group("Fallen", "Config")
        menu.add_combo("Fallen", "Config", "config_slot", "Config Slot", slot_display_names, 0, {
            callback = function(val)
                local slot = val + 1
                update_slot_names()
                local current_name = slot_display_names[slot]
                safe_notify("Selected: " .. current_name, "info")
            end
        })
        menu.add_button("Fallen", "Config", "save_config", "Save Config", function()
            local slot = menu.get("config_slot") + 1
            local name = "Fallen_Config_Slot_" .. slot .. ".txt"
            save_config(name)
        end)
        menu.add_button("Fallen", "Config", "load_config", "Load Config", function()
            local slot = menu.get("config_slot") + 1
            local name = "Fallen_Config_Slot_" .. slot .. ".txt"
            load_config(name)
        end)
        menu.add_button("Fallen", "Config", "rename_config", "Rename Config Slot", function()
            local slot = menu.get("config_slot") + 1
            rename_config_with_input(slot)
        end)
        menu.add_button("Fallen", "Config", "list_configs", "Refresh Slots", function()
            update_slot_names()
            local found = {}
            for i = 1, 5 do
                table.insert(found, i .. ": " .. slot_display_names[i])
            end
            safe_notify("Current Slots:\n" .. table.concat(found, "\n"), "info")
        end)
        menu.add_button("Fallen", "Config", "delete_config", "Clear Slot", function()
            local slot = menu.get("config_slot") + 1
            local name = "Fallen_Config_Slot_" .. slot .. ".txt"
            local path = get_config_path(name)
            if _isfile(path) then
                _delfile(path)
                safe_notify("Cleared Slot " .. slot, "success")
            else
                safe_notify("Slot " .. slot .. " is already empty", "warning")
            end
        end)
    --
end

